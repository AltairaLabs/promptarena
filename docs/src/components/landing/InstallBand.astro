---
import CopyButton from './CopyButton.astro';
import { icon } from './icons';

const commands = [
  'npm i -g @altairalabs/promptarena @altairalabs/packc',
  'brew install altairalabs/tap/promptarena',
];
---

<section class="install">
  <div class="atlas-inner grid">
    <div class="col-left">
      <p class="eyebrow">INSTALL</p>
      <h2>Two CLIs. One command away.</h2>
      <p class="copy">
        <code>promptarena</code> runs your scenarios; <code>packc</code> compiles and pins
        your packs. The runtime that executes them ships in
        <a href="https://promptkit.altairalabs.ai">PromptKit</a>.
      </p>
      <div class="cta">
        <a class="btn-primary" href="/arena/tutorials/01-first-test/">
          Get started <span set:html={icon('arrow-right', 16)} />
        </a>
        <a class="btn-text" href="/arena/tutorials/01-first-test/">
          Read the quickstart <span set:html={icon('external', 14)} />
        </a>
      </div>
    </div>
    <div class="col-right">
      {
        commands.map((c) => (
          <div class="cmd-row">
            <code><span class="prompt">$</span> {c}</code>
            <CopyButton command={c} />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .install {
    padding: 70px 30px;
    border-top: 1px solid var(--hairline);
    background: var(--atmo-gold), var(--bg-app);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .eyebrow {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ion-cyan);
  }
  h2 {
    margin: 0;
    font-weight: 600;
    font-size: 32px;
    line-height: 1.14;
    letter-spacing: -0.02em;
    color: var(--star-100);
  }
  .copy {
    margin: 16px 0 0;
    max-width: 460px;
    font-size: 16px;
    line-height: 1.6;
    color: var(--star-600);
  }
  .copy code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--ion-cyan);
  }
  .copy a {
    color: var(--nebula-violet);
  }
  .cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    margin-top: 26px;
  }
  .btn-primary,
  .btn-text {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    border-radius: var(--radius-btn);
    transition: all var(--dur-base) var(--ease-standard);
  }
  .btn-primary {
    padding: 12px 20px;
    font-size: 14px;
    background: var(--gold-500);
    color: var(--gold-ink);
    box-shadow: 0 8px 22px -8px rgba(227, 179, 65, 0.5);
  }
  .btn-primary:hover {
    background: var(--gold-300);
  }
  .btn-text {
    font-size: 14px;
    color: var(--star-700);
  }
  .btn-text:hover {
    color: var(--star-200);
  }
  .btn-primary :global(svg),
  .btn-text :global(svg) {
    display: block;
  }

  .col-right {
    display: grid;
    gap: 12px;
  }
  .cmd-row {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-code);
    background: var(--surface-code);
    padding: 15px 16px;
  }
  .cmd-row code {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 13.5px;
    color: var(--star-300);
    overflow-x: auto;
    white-space: nowrap;
  }
  .cmd-row .prompt {
    color: var(--star-700);
    margin-right: 8px;
  }
  @media (max-width: 880px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
