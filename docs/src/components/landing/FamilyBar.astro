---
// Masterbrand family bar (40px). Gold appears here only as the AltairaLabs
// identity — not a CTA.
---

<div class="family-bar">
  <div class="atlas-inner row">
    <a class="brand" href="https://altairalabs.ai">
      <img class="star-tile" src="/atlas/star-glyph-gold.svg" width="17" height="17" alt="" />
      <span class="wordmark"><span class="altaira">ALTAIRA</span><span class="labs">LABS</span></span>
    </a>
    <div class="right">
      <span class="switcher">
        <span class="dot"></span>PromptArena <span class="caret">&#9662;</span>
      </span>
      <a href="https://altairalabs.ai/products">Products</a>
      <a href="https://altairalabs.ai/blog">Blog</a>
    </div>
  </div>
</div>

<style>
  .family-bar {
    height: 40px;
    background: var(--ink-void);
    border-bottom: 1px solid var(--hairline-faint);
  }
  .row {
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 30px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .wordmark {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.1em;
  }
  .altaira {
    color: var(--star-200);
  }
  .labs {
    color: var(--gold-500);
  }
  .right {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    font-size: 12px;
  }
  .switcher {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    border: 1px solid var(--hairline-strong);
    border-radius: var(--radius-btn);
    padding: 6px 11px;
    color: var(--star-300);
    font-weight: 500;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--ion-cyan);
  }
  .caret {
    color: var(--star-700);
  }
  .right a {
    color: var(--star-700);
    transition: color var(--dur-base) var(--ease-standard);
  }
  .right a:hover {
    color: var(--star-200);
  }
  @media (max-width: 640px) {
    .switcher,
    .right a {
      display: none;
    }
  }
</style>
