---
import ThemeToggle from './ThemeToggle.astro';
import versions from '../../../versions.json';

const v = versions.current.version;
const links = [
  { label: 'Arena', href: '/arena/' },
  { label: 'PackC', href: '/packc/' },
  { label: 'Docs', href: '/arena/', active: true },
  { label: 'Reference', href: '/arena/reference/' },
];
---

<nav class="product-nav">
  <div class="atlas-inner row">
    <div class="left">
      <a class="brand" href="/">
        <img src="/atlas/logo-promptarena.svg" width="26" height="26" alt="" />
        <span class="name">PromptArena</span>
      </a>
      <ul class="links">
        {
          links.map((l) => (
            <li>
              <a href={l.href} class={l.active ? 'active' : ''}>
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="right">
      <span class="version">v{v}</span>
      <ThemeToggle />
      <a class="open-arena" href="/arena/">Open arena</a>
    </div>
  </div>
</nav>

<style>
  .product-nav {
    background: var(--ink-canvas);
    border-bottom: 1px solid var(--hairline);
  }
  .row {
    height: 62px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 30px;
  }
  .left {
    display: flex;
    align-items: center;
    gap: 34px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .name {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 16px;
    color: var(--star-100);
  }
  .links {
    display: flex;
    align-items: center;
    gap: 26px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .links a {
    font-weight: 500;
    font-size: 13.5px;
    color: var(--star-700);
    transition: color var(--dur-base) var(--ease-standard);
  }
  .links a.active {
    color: var(--star-500);
  }
  .links a:hover {
    color: var(--star-200);
  }
  .right {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .version {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--star-900);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-tag);
    padding: 4px 8px;
  }
  .open-arena {
    font-weight: 600;
    font-size: 13px;
    color: var(--ion-cyan);
    border: 1px solid rgba(103, 232, 249, 0.4);
    border-radius: var(--radius-btn);
    padding: 9px 14px;
    transition: border-color var(--dur-base) var(--ease-standard);
  }
  .open-arena:hover {
    border-color: var(--ion-cyan);
  }
  @media (max-width: 780px) {
    .links {
      display: none;
    }
  }
</style>
